<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F0F4FF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HERO SECTION ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="650dp"
                android:background="@color/black"
                android:gravity="start"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/first_line_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:gravity="start"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:layout_marginTop="10dp"
                    android:gravity="start"
                    android:text="@string/second_line"
                    android:textColor="#898C95"
                    android:textSize="15sp" />

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="#33AF24"
                    android:text="Get Started →"
                    android:textColor="#FFFFFF"
                    android:layout_gravity="start"/>

                <!-- Container with border -->


                    <!-- Container border (bottom layer) -->
                    <LinearLayout
                        android:id="@+id/logo_container"
                        android:layout_width="250dp"
                        android:layout_height="250dp"
                        android:layout_gravity="center"
                        android:background="@drawable/container_default"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_marginTop="40dp"
                        android:layout_marginBottom="0dp">

                        <!-- Image floats above container (top layer) -->
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/logo_image"
                            android:layout_width="220dp"
                            android:layout_height="220dp"
                            android:layout_gravity="center"
                            android:src="@drawable/logo2"
                            android:scaleType="centerInside"
                            android:translationZ="4dp"
                            android:background="#121111"
                            android:padding="10dp"
                            app:shapeAppearanceOverlay="@style/RoundedSquareImage"/>
                    </LinearLayout>


            </LinearLayout>


            <!-- Single content block that auto updates -->
            <LinearLayout
                android:id="@+id/content_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_bg1"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">


                <TextView
                    android:id="@+id/offer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/line3"
                    android:textSize="35sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    />

                <!-- Yellow underline -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#FACC15"
                    android:layout_marginHorizontal="70dp"
                    android:layout_marginBottom="40dp"/>

                <!-- Title -->
                <TextView
                    android:id="@+id/item_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="4dp"/>

                <!-- Red underline -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#DC0917"
                    android:layout_marginBottom="10dp"
                    android:layout_marginHorizontal="50dp"/>

                <!-- Body -->
                <TextView
                    android:id="@+id/item_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#CCCCCC"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="12dp"/>

                <!-- Image -->
                <ImageView
                    android:id="@+id/item_image"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"/>

            </LinearLayout>


            <!-- why choose peerprep? -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/black"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="3dp"
                    android:text="@string/line4"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="30dp"
                    />

                <!-- Yellow underline -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#FACC15"
                    android:layout_marginBottom="40dp"
                    android:layout_marginHorizontal="70dp"/>


                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp">

                    <ImageView
                        android:id="@+id/img1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/p13"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="#99000000"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="Personalized Attention"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </FrameLayout>

                <!-- Image 2 -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp">

                    <ImageView
                        android:id="@+id/img2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/p166"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="#99000000"
                        android:padding="10dp"
                        android:gravity="center"
                        android:text="Expert Tutors, Real Results"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </FrameLayout>

                <!-- Image 3 -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp">

                    <ImageView
                        android:id="@+id/img3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/p14"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="#99000000"
                        android:padding="10dp"
                        android:gravity="center"
                        android:text="Affordable &amp; Student-First"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </FrameLayout>

                <!-- Image 4 -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp">

                    <ImageView
                        android:id="@+id/img4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/p6"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="#99000000"
                        android:padding="10dp"
                        android:text="Support Beyond The Syllabus"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </FrameLayout>

                <!-- Image 5 -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp">

                    <ImageView
                        android:id="@+id/img5"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/p7"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="#99000000"
                        android:padding="10dp"
                        android:gravity="center"
                        android:text="Fun &amp; Educational Events"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </FrameLayout>

                <!-- Image 6 -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp">

                    <ImageView
                        android:id="@+id/img6"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/p111"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:gravity="center"
                        android:background="#99000000"
                        android:padding="10dp"
                        android:text="Every Class Is Auto-Recorded + 2 Free Test Sessions Monthly"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </FrameLayout>


            </LinearLayout>


            <!-- serving student across the globe -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/black">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="3dp"
                    android:text="@string/line5"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="30dp"
                    android:layout_gravity="center_horizontal"
                    />

                <!-- Yellow underline -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#FACC15"
                    android:layout_marginBottom="40dp"
                    android:layout_marginHorizontal="80dp"/>

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ind"
                            android:scaleType="centerCrop"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#99000000"
                            android:padding="10dp"
                            android:text="India"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"/>

                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/uk2"
                            android:scaleType="centerCrop"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#99000000"
                            android:padding="10dp"
                            android:text="UK"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"/>

                    </FrameLayout>

                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/usa2"
                            android:scaleType="centerCrop"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#99000000"
                            android:padding="10dp"
                            android:text="USA"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"/>

                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/aus"
                            android:scaleType="centerCrop"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#99000000"
                            android:padding="10dp"
                            android:text="Australia"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"/>

                    </FrameLayout>

                </LinearLayout>

                <!-- Row 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/canda2"
                            android:scaleType="centerCrop"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#99000000"
                            android:padding="10dp"
                            android:text="Canada"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"/>

                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/mideast"
                            android:scaleType="centerCrop"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#99000000"
                            android:padding="10dp"
                            android:text="Middle East"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"/>

                    </FrameLayout>

                </LinearLayout>


                <!-- book a demo-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/black">

                    <!-- Image on top with rounded corners -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="280dp"
                        android:layout_margin="16dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/demo"
                            android:scaleType="centerCrop"
                            android:layout_marginTop="20dp"/>

                    </androidx.cardview.widget.CardView>

                    <!-- Text Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:paddingBottom="32dp">

                        <!-- Title -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Book a Demo"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginBottom="16dp"/>

                        <!-- Description -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Book your free demo today, and take the first step towards smarter, stress-free learning."
                            android:textColor="#AAAAAA"
                            android:textSize="15sp"
                            android:gravity="center"
                            android:lineSpacingMultiplier="1.5"
                            android:layout_marginBottom="24dp"/>

                        <!-- Button -->
                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Book a Free trial →"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:backgroundTint="#2979FF"
                            android:paddingStart="32dp"
                            android:paddingEnd="32dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            app:cornerRadius="50dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- get in touch -->
                <ScrollView
                    xmlns:android="http://schemas.android.com/apk/res/android"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_bg2">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Title -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Get in Touch"
                            android:textColor="#FFFFFF"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp"/>

                        <!-- Subtitle -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Have questions, feedback or want to book a demo? We're just a message away."
                            android:textColor="#AAAAAA"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.5"
                            android:layout_marginBottom="24dp"/>

                        <!-- Address Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <!-- Location Icon -->
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_location"
                                app:tint="#2979FF"
                                android:layout_marginEnd="12dp"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Address:"
                                    android:textColor="#FFFFFF"
                                    android:textSize="15sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Dehradun, 248001"
                                    android:textColor="#AAAAAA"
                                    android:textSize="14sp"/>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Phone Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <!-- Phone Icon -->
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_phone"
                                app:tint="#2979FF"
                                android:layout_marginEnd="12dp"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Phone:"
                                    android:textColor="#FFFFFF"
                                    android:textSize="15sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+91 6206359673"
                                    android:textColor="#AAAAAA"
                                    android:textSize="14sp"/>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Email Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="32dp">

                            <!-- Email Icon -->
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_email"
                                app:tint="#2979FF"
                                android:layout_marginEnd="12dp"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Email:"
                                    android:textColor="#FFFFFF"
                                    android:textSize="15sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="peerprepeducation@outlook.com"
                                    android:textColor="#2979FF"
                                    android:textSize="14sp"/>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Contact Image with rounded corners -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#232633">

                            <LinearLayout

                                android:layout_width="250dp"
                                android:layout_height="250dp"
                                android:layout_gravity="center"
                                android:background="#232633"
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:layout_margin="10dp">

                                <!-- Image floats above container (top layer) -->
                                <com.google.android.material.imageview.ShapeableImageView

                                    android:layout_width="230dp"
                                    android:layout_height="230dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/contactus3"
                                    android:scaleType="centerInside"
                                    android:translationZ="4dp"
                                    android:padding="10dp"
                                    app:shapeAppearanceOverlay="@style/RoundedSquareImage"/>
                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                </ScrollView>


            </LinearLayout>


            <!-- ✅ Footer Fragment — add at bottom of every page -->
            <fragment
                android:id="@+id/footerFragment"
                android:name="com.bond.peerprep.FooterFragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_book"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="10dp"
        android:text="Book a Free Trial →"
        android:textColor="#FFFFFF"
        app:backgroundTint="#2979FF"
        app:cornerRadius="20dp"
        app:icon="@null"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>