<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#0D1B4B"

    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0B011F"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:id="@+id/why_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Why kids love learning Science with Peer Prep"
            android:textColor="#00E5CC"
            android:textSize="26sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="32dp"/>

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <!-- Item 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/icon1"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_experiment"
                    android:background="@drawable/circle_icon_bg"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    app:tint="#3949AB"/>

                <TextView
                    android:id="@+id/text1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hands-on experiments &amp; demonstrations"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

            <!-- Item 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/icon2"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_world"
                    android:background="@drawable/circle_icon_bg"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    app:tint="#3949AB"/>

                <TextView
                    android:id="@+id/text2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Real world scientific applications"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

            <!-- Item 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/icon3"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_bulb"
                    android:background="@drawable/circle_icon_bg"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    app:tint="#3949AB"/>

                <TextView
                    android:id="@+id/text3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Concept clarity with animations"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Item 4 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/icon4"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_star"
                    android:background="@drawable/circle_icon_bg"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    app:tint="#3949AB"/>

                <TextView
                    android:id="@+id/text4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CBSE &amp; ICSE aligned curriculum"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

            <!-- Item 5 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/icon5"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_check"
                    android:background="@drawable/circle_icon_bg"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    app:tint="#3949AB"/>

                <TextView
                    android:id="@+id/text5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Certified science mentors"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

            <!-- Item 6 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/icon6"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_star"
                    android:background="@drawable/circle_icon_bg"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    app:tint="#3949AB"/>

                <TextView
                    android:id="@+id/text6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="International science standards"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>