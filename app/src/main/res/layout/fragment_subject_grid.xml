<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:id="@+id/grid_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Why Science?"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/grid_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Practical learning that builds curiosity and scientific thinking."
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="20dp"/>

    <!-- 3 Cards Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Card 1 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#99000000">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">

                <!-- Circular Image -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/card1_image"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/p6"
                    app:shapeAppearanceOverlay="@style/CircleImageView"
                    android:layout_marginBottom="12dp"/>

                <!-- Title -->
                <TextView
                    android:id="@+id/card1_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Physics"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp"/>

                <!-- Description -->
                <TextView
                    android:id="@+id/card1_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Motion, force, energy and real-world experiments."
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Card 2 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#99000000">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">

                <!-- Circular Image -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/card2_image"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/p3"
                    app:shapeAppearanceOverlay="@style/CircleImageView"
                    android:layout_marginBottom="12dp"/>

                <!-- Title -->
                <TextView
                    android:id="@+id/card2_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chemistry"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp"/>

                <!-- Description -->
                <TextView
                    android:id="@+id/card2_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chemical reactions, acids, bases and lab activities."
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Card 3 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#99000000">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">

                <!-- Circular Image -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/card3_image"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/p8"
                    app:shapeAppearanceOverlay="@style/CircleImageView"
                    android:layout_marginBottom="12dp"/>

                <!-- Title -->
                <TextView
                    android:id="@+id/card3_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Biology"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp"/>

                <!-- Description -->
                <TextView
                    android:id="@+id/card3_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Human body, plants, animals and life processes."
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>