<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/subject_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- SubjectCardFragment container -->
        <FrameLayout
            android:id="@+id/coding_subject_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- SubjectGridFragment container -->
        <FrameLayout
            android:id="@+id/coding_subject_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- CurriculumFragment container -->
        <FrameLayout
            android:id="@+id/coding_curriculum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- WhyUsFragment container -->
        <FrameLayout
            android:id="@+id/coding_why_us"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>



        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready to Explore Coding?"
            android:textSize="20dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginVertical="20dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="20dp">

            <Button
                android:id="@+id/card_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Book a FREE trial →"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#1a1a6a"
                app:cornerRadius="50dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/instructors_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore Instructors →"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#1a1a6a"
                app:cornerRadius="50dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"/>

        </LinearLayout>


        <!-- footer fragment-->
        <fragment
            android:id="@+id/footerFragment"
            android:name="com.bond.peerprep.FooterFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>