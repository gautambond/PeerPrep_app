<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1035"
    android:padding="20dp">

    <TextView
        android:id="@+id/dialog_schedule_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Subject -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxBackgroundColor="#2D2B6B"
        app:boxStrokeColor="#2979FF"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/dialog_subject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Subject name"
            android:textColor="#FFFFFF"
            android:textColorHint="#777777"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Time -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxBackgroundColor="#2D2B6B"
        app:boxStrokeColor="#2979FF"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/dialog_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Monday 10:00 AM"
            android:textColor="#FFFFFF"
            android:textColorHint="#777777"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Zoom Link -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxBackgroundColor="#2D2B6B"
        app:boxStrokeColor="#2979FF"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/dialog_zoom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Zoom meeting link"
            android:textColor="#FFFFFF"
            android:textColorHint="#777777"
            android:inputType="textUri"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Post Button -->
    <Button
        android:id="@+id/dialog_post_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Post Schedule"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2979FF"
        app:cornerRadius="12dp"/>

</LinearLayout>